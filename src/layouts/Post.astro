---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;

const dateObj = new Date(frontmatter.date);
const formatted = isNaN(dateObj.getTime())
  ? String(frontmatter.date)
  : dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<Layout title={`${frontmatter.title} — Jaydeep Deshpande`} description={frontmatter.description ?? frontmatter.title}>
  <header>
    <h1>Jaydeep Deshpande</h1>
    <p class="tagline">Energy engineer &middot; <a href="https://www.cfs.energy/">Commonwealth Fusion Systems</a> &middot; Boston</p>
    <nav>
      <a href="/#projects">Projects</a>
      <a href="/#research">Research</a>
      <a href="/#shelf">On my shelf</a>
    </nav>
    <div class="social">
      <a href="https://github.com/jaydeshpande">GitHub</a>
      <a href="https://scholar.google.com/citations?user=ggvoStcAAAAJ&hl=en">Scholar</a>
      <a href="https://www.linkedin.com/in/jaydeepdeshpande/">LinkedIn</a>
      <a href="https://twitter.com/TheDeshpande">X</a>
    </div>
    <button id="theme-toggle" aria-label="Toggle dark mode">☾ dark</button>
  </header>

  <main>
    <a href="/" class="back-link">← All writing</a>
    <div class="post-header">
      <h1>{frontmatter.title}</h1>
      <time datetime={frontmatter.date}>{formatted}</time>
    </div>
    <div class="post-body">
      <slot />
    </div>
  </main>

  <footer>
    <a href="/">jaydeep.info</a>
  </footer>
</Layout>
